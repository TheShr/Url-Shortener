# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/urlshortener
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=20
CACHE_TTL_SECONDS=3600        # 1 hour for hot URLs
RATE_LIMIT_TTL_SECONDS=60

# ── App ───────────────────────────────────────────────────────────────────────
BASE_DOMAIN=http://localhost:8000
SECRET_KEY=replace-with-a-strong-secret-key-in-production
ENVIRONMENT=development

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_SHORTEN=10/minute   # per IP
RATE_LIMIT_REDIRECT=120/minute

# ── URL Config ────────────────────────────────────────────────────────────────
DEFAULT_EXPIRY_DAYS=365
MAX_CUSTOM_ALIAS_LENGTH=32
SHORT_CODE_LENGTH=7

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.vercel.app
